# Site
NEXT_PUBLIC_SITE_URL=https://tehuset.example

# TinaCMS local/dev. For self-hosted production, point these to your git-backed Tina auth/content service.
NEXT_PUBLIC_TINA_CLIENT_ID=local
TINA_TOKEN=local
GITHUB_BRANCH=main

# Swish (QR to your Swish number — no merchant certificate needed).
# Set this to the number that should receive merch payments, e.g. 0701234567.
SWISH_NUMBER=

# Email confirmation: sends a "thank you" to the customer and an order
# notification to adminEmail (content/site.json). Use your mail provider's SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ORDER_EMAIL_FROM=
